# Скопіюй цей файл як .env.local і встав свій ключ Gemini API
# Отримати: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Модель Gemini (необов'язково, default: gemini-2.0-flash)
# Варіанти: gemini-2.0-flash | gemini-2.0-flash-lite | gemini-2.5-flash
# GEMINI_MODEL=gemini-2.0-flash
